generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  password       String
  email          String?  @unique
  wikidotAccount String?
  balance        Float    @default(10000)
  createdAt      DateTime @default(now())
  isAdmin        Boolean  @default(false)
  status         String   @default("active") // 新增此行用于封禁状态管理

  images         Image[]
  trades         Trade[]
  gachas         Gacha[]
}

model TempReg {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  verifyCode String
  password   String
  wdid       String?
  expiresAt  DateTime
}

model Image {
  id          Int      @id @default(autoincrement())
  url         String
  title       String?
  description String?
  createdAt   DateTime @default(now())

  uploaderId  Int
  uploader    User     @relation(fields: [uploaderId], references: [id])
}

model Trade {
  id        Int      @id @default(autoincrement())
  data      Json
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Gacha {
  id        Int      @id @default(autoincrement())
  data      Json
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Setting {
  key   String @id
  value String
}

// 页面备份存档
model PageArchive {
  id        Int      @id @default(autoincrement())
  wiki      String   // 站点代码 (如 dfc, if, scp)
  slug      String   // 页面路径 (如 page-name)
  title     String?  // 页面标题
  content   String?  // 页面正文 HTML
  author    String?  // 页面作者
  tags      String?  // 页面标签 (空格分隔)
  sourceUrl String?  // 原始链接
  images    Json?    // 页面内的图片资源 (数组)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([wiki, slug])
}

// 邮箱验证码
model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime
}