generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  password       String
  email          String?  @unique
  wikidotAccount String?  @unique // 必须唯一，防止多号一绑
  balance        Decimal  @default(10000) @db.Decimal(20, 2) // 明确精度
  createdAt      DateTime @default(now())
  isAdmin        Boolean  @default(false)
  status         UserStatus @default(ACTIVE)

  images         Image[]
  trades         Trade[]
  gachas         Gacha[]
  
  @@index([username])
}

model TempReg {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  verifyCode String
  password   String
  wdid       String?
  expiresAt  DateTime
}

model Image {
  id          Int      @id @default(autoincrement())
  url         String
  title       String?
  description String?
  createdAt   DateTime @default(now())

  uploaderId  Int
  uploader    User     @relation(fields: [uploaderId], references: [id])

  @@index([uploaderId])
}

// 结构化 Trade 表，告别 Json 乱炖
model Trade {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  
  type        TradeType 
  amount      Decimal  @db.Decimal(20, 2)
  target      String?  // 交易目标（如作者ID、物品名）
  description String?
  status      String   @default("COMPLETED")
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// 结构化 Gacha 表
model Gacha {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  poolId    String   // 抽卡池ID
  result    String   // 抽卡结果
  cost      Decimal  @db.Decimal(20, 2)
  
  createdAt DateTime @default(now())

  @@index([userId])
}

model Setting {
  key   String @id
  value Json
}

model PageArchive {
  id        Int      @id @default(autoincrement())
  wiki      String   // 站点代码 (如 dfc, if, scp)
  slug      String   // 页面路径 (如 page-name)
  title     String?  
  content   String?  @db.Text // 明确使用 Text 类型
  author    String?  
  sourceUrl String?  
  images    Json?    
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  tags      Tag[]    // 改为多对多关系

  @@unique([wiki, slug])
  @@index([author])
}

model Tag {
  id      Int           @id @default(autoincrement())
  name    String        @unique
  pages   PageArchive[]
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum TradeType {
  BUY
  SELL
  TRANSFER
  ADJUST
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  method    String
  path      String
  status    Int
  ip        String?
  userAgent String?
  username  String?
  duration  Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}
